# ==================== 基础配置 ====================
APP_NAME=ChatUI
APP_URL=http://localhost:3000

# ==================== 安全配置（必改） ====================
# 随机字符串，用于 session 加密。推荐: openssl rand -hex 32
SESSION_SECRET=replace-with-a-strong-random-secret

# 管理员初始账号（首次启动自动创建）
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password

# ==================== AI API 配置 ====================
# OpenAI 兼容 API（必填）
OPENAI_API_KEY=sk-xxx

# API 地址（配置优先级：数据库 ApiConfig 表 > 此环境变量）
# 官方: https://api.openai.com/v1
# 公网代理: https://cpa.rcrc.eu.org/v1
# Docker 内网（同主机容器互联时）: http://cliproxyapi:8317/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# ==================== 模型配置 ====================
DEFAULT_CHAT_MODEL=gpt-5.4-mini
DEFAULT_IMAGE_MODEL=gpt-image-2

# 允许使用的模型列表（逗号分隔）
ALLOWED_CHAT_MODELS=gpt-5.4-mini,gpt-5.4,gpt-5.5
ALLOWED_IMAGE_MODELS=gpt-image-2

# ==================== 数据库 ====================
DATABASE_URL=file:/app/data/prod.db
NODE_ENV=production
